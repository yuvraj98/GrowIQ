# ═══════════════════════════════════════════════
# GrowIQ Backend — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (PostgreSQL) ────────────────────
# For local Docker: use defaults below
# For Supabase Free: use your Supabase connection string
# For Neon Free: use your Neon connection string
DB_HOST=localhost
DB_PORT=5432
DB_NAME=growiq_development
DB_USER=growiq
DB_PASSWORD=growiq_dev_2026

# ─── Redis ────────────────────────────────────
# For local Docker: use defaults below
# For Upstash Free: use your Upstash credentials
# Leave empty to run without Redis (caching disabled)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT Authentication ──────────────────────
JWT_SECRET=growiq-dev-secret-change-in-production-2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=growiq-refresh-secret-change-in-production-2026
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI Service ──────────────────────────────
# Set to 'mock' for free development (no API calls)
# Set to 'live' when testing with real Claude API
AI_SERVICE_MODE=mock
ANTHROPIC_API_KEY=

# ─── External APIs Toggle ────────────────────
# Set to 'true' for mock data (free development)
USE_MOCK_APIS=true

# ─── Razorpay (Payments) ─────────────────────
# Use TEST mode keys (free, unlimited test transactions)
# Get test keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_MODE=test

# ─── Email Service ───────────────────────────
# 'ethereal' = fake inbox (100% free, no real emails)
# 'sendgrid' = SendGrid Free (100 emails/day)
EMAIL_SERVICE=ethereal
SENDGRID_API_KEY=
EMAIL_FROM=noreply@growiq.in

# ─── File Storage ────────────────────────────
# Set USE_S3=false for local filesystem (free)
# Set USE_S3=true + AWS keys for production S3
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=growiq-files

# ─── Frontend URL ────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── WhatsApp ────────────────────────────────
# 'mock' = console.log only (free)
# 'live' = 360dialog API (paid)
WHATSAPP_MODE=mock
WHATSAPP_API_KEY=

# ─── Meta Ads API ────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ─── Google APIs ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SEMrush ─────────────────────────────────
SEMRUSH_API_KEY=

# ─── Logging ─────────────────────────────────
LOG_LEVEL=info
