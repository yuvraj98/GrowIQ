# GrowIQ Environment Variables
# Copy this file to .env and fill in the secrets

# 🌐 Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 🗄️ Database (PostgreSQL)
DATABASE_URL=postgres://username:password@localhost:5432/growiq

# 🔐 Security
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# 📧 Email (Optional - for notifications/reports)
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_USER=your_user
# SMTP_PASS=your_pass

# 🤖 AI Engine Configuration
ANALYSIS_CRON="0 0 * * *"
WEEKLY_REPORT_CRON="0 3 * * 1"

# 💳 Payment Gateways (Future)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
